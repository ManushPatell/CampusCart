{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "skipDefaultLibCheck": true,
  },
  
  "include": ["src/**/*"],
}
